{
  "installCommand": "cd stonewater-rag-ui && npm install",
  "buildCommand": "cd stonewater-rag-ui && npm run build",
  "outputDirectory": "stonewater-rag-ui/build",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
